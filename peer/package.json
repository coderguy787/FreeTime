{
  "name": "freetime-peer-server",
  "version": "1.0.0",
  "description": "FreeTime Peer Server - Distributed messaging, calls, and account verification for 80k concurrent users",
  "main": "peer-server.js",
  "scripts": {
    "start": "node peer-server.js",
    "start:prod": "NODE_ENV=production node peer-server.js",
    "start:dev": "NODE_ENV=development nodemon peer-server.js",
    "control": "node peer-controller.js",
    "setup": "bash setup.sh",
    "test": "jest --detectOpenHandles",
    "lint": "eslint .",
    "cluster": "node --expose-gc peer-server.js"
  },
  "keywords": [
    "freetime",
    "peer-to-peer",
    "messaging",
    "voip",
    "distributed"
  ],
  "author": "FreeTime",
  "license": "MIT",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.4.0",
    "body-parser": "^1.20.2",
    "cluster": "",
    "compression": "^1.7.4",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "net": "",
    "os": "",
    "redis": "^4.6.8",
    "socket.io": "^4.6.1",
    "socket.io-redis": "^6.1.1",
    "uuid": "^9.0.0",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "eslint": "^8.44.0",
    "jest": "^29.6.1",
    "nodemon": "^2.0.22",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "os": [
    "linux",
    "win32"
  ]
}
